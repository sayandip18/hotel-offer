              "body": "[\n  { \"hotelId\": \"b1\", \"name\": \"Holtin\",       \"price\": 5340, \"city\": \"delhi\", \"commissionPct\": 20 },\n  { \"hotelId\": \"b2\", \"name\": \"Radison\",      \"price\": 6200, \"city\": \"delhi\", \"commissionPct\": 11 },\n  { \"hotelId\": \"b3\", \"name\": \"Grand Hyatt\",  \"price\": 8100, \"city\": \"delhi\", \"commissionPct\": 14 },\n  { \"hotelId\": \"b4\", \"name\": \"Bloom Suites\", \"price\": 4500, \"city\": \"delhi\", \"commissionPct\": 9  },\n  { \"hotelId\": \"b5\", \"name\": \"Lemon Tree\",   \"price\": 3500, \"city\": \"delhi\", \"commissionPct\": 10 }\n]"
